# ---- Core ----
NODE_ENV=development

# ---- Database ----
# Postgres connection string. On Render, this is supplied by the managed DB.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emr

# ---- Authentication ----
AUTH_PROVIDER=clerk

# --- Clerk (required when AUTH_PROVIDER=clerk) ---
# Get these from clerk.com → Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# From Clerk Dashboard → Webhooks → Endpoint → Signing Secret
# (create the endpoint at https://<your-domain>/api/webhooks/clerk
#  and subscribe to user.created, user.updated, user.deleted)
CLERK_WEBHOOK_SECRET=
# Tell Clerk where to redirect after sign-in / sign-up.
# After-sign-in MUST be /post-sign-in (the role resolver) — sending every role
# through /portal (the patient shell) was the old "logged in but bounced" bug.
# Sign-up stays /portal on purpose (new accounts are patients; avoids the
# webhook-lag race). Note the <SignIn>/<SignUp> components also set
# forceRedirectUrl explicitly, so these are fallbacks for other entry points.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/post-sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/portal

# Bare HTTPS portal origin used by pre-visit completion reminders.
# Leave blank locally to keep those nudges quarantined.
PREVISIT_PORTAL_URL=

# --- Transactional email (Resend) ---
# Powers practice-invite emails (and other transactional sends). When unset,
# sendEmail() no-ops gracefully and invites fall back to the "Copy link" path.
RESEND_API_KEY=
# Optional From: override (defaults to Resend's test sender until a domain is
# verified). e.g. "Leafjourney <whispers@leafjourney.com>"
EMAIL_FROM=

# --- Super-admin bootstrap ---
# Comma-separated emails that get auto-promoted to super_admin on first
# sign-in / on `npm run db:seed`. This is the recovery path; once one of
# these accounts is promoted, they can grant the role to anyone else
# through the /admin console (so you can also remove them from this list).
SUPER_ADMIN_BOOTSTRAP_EMAILS=

# ---- Agent harness ----
# Which model client to use. "stub" for local dev / CI (deterministic, no
# network). "openrouter" for real LLM calls via OpenRouter.
AGENT_MODEL_CLIENT=stub

# OpenRouter configuration — required when AGENT_MODEL_CLIENT=openrouter.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional. Any model slug supported by OpenRouter. Defaults to Claude Sonnet 4.5.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional. Used for OpenRouter attribution headers (shows up in your dashboard).
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Leafjourney

# ---- Visit dictation / transcription ----
# Which speech-to-text provider to use for voice-chart recordings.
#   "simulated" (default)    — no network calls; voice-chart uses a
#                              hardcoded demo transcript. Good for CI
#                              and local dev without API keys.
#   "openai-whisper"         — POSTs the recording to OpenAI Whisper
#                              (/v1/audio/transcriptions, whisper-1,
#                              verbose_json). Requires OPENAI_API_KEY.
TRANSCRIPTION_PROVIDER=simulated

# OpenAI key, used when TRANSCRIPTION_PROVIDER=openai-whisper.
# Whisper's 25 MB payload cap covers ~25 min of typical voice audio.
# Segment-level timestamps are returned; speaker diarization is NOT —
# every segment comes back as speaker="unknown" and the extraction
# prompt handles unlabeled turns. Swap provider for real diarization.
OPENAI_API_KEY=

# ---- Object storage (Supabase Storage for documents) ----
# Create a private bucket named "documents" in your Supabase project.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=documents

# ---- Linear integration ----
# Personal API key from Linear (Settings -> API -> Personal API keys).
# Used by internal tooling to fetch issue specs + pinned briefing comments.
LINEAR_API_KEY=

# ---- Inbound SMS gateway (EMR-1145, /api/webhooks/sms-inbound) ----
# Shared secret the SMS provider must send in the `x-sms-webhook-secret`
# header. The route fails closed (503) when unset — generate with
# `openssl rand -hex 32` and configure the same value on the provider side.
SMS_WEBHOOK_SECRET=

# ---- Garmin Health API integration (EMR-054) ----
# The patient portal Garmin connection is GATED on these credentials. With
# BOTH key+secret set, the integration runs LIVE (real OAuth 1.0a + real
# Health API). With neither set, Garmin shows "Coming soon" and cannot write
# to any chart. There is no way to reach the simulated path in production.
#
# Garmin "Consumer Key/Secret" from the Garmin Developer Portal (Health API
# program). Register the OAuth callback as
#   https://<your-domain>/api/integrations/garmin/callback
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
# Shared secret guarding the inbound push/ping webhook (Garmin does not sign
# its pushes). Register the webhook as
#   https://<your-domain>/api/integrations/garmin/webhook?token=<this value>
# The route fails closed (503) when unset. Generate with `openssl rand -hex 32`.
GARMIN_WEBHOOK_TOKEN=
# DEV/DEMO ONLY: set to "true" (with NO Garmin credentials, in a non-production
# NODE_ENV) to enable simulated Garmin data. Everything it writes is tagged
# "(SIMULATED)". Ignored in production.
GARMIN_ALLOW_MOCK=

# At-rest encryption key for stored integration OAuth tokens (32 bytes hex,
# `openssl rand -hex 32`). Falls back to MESSAGE_ENCRYPTION_KEY /
# DOCUMENT_ENCRYPTION_KEY when unset; production should set a dedicated key.
INTEGRATION_TOKEN_ENCRYPTION_KEY=

# ---- Oura Ring (OAuth 2.0, API v2) ----
# From the Oura Cloud developer console. With both set, the Oura card goes
# LIVE; unset => "Coming soon". Register the redirect URI as
#   https://<your-domain>/api/integrations/oauth2/oura/callback
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
# Shared secret for the Oura webhook (subscription verification + event guard):
#   https://<your-domain>/api/integrations/webhook/oura?token=<this value>
OURA_WEBHOOK_TOKEN=

# ---- Whoop (OAuth 2.0, API v1) ----
# From the Whoop developer dashboard. Redirect URI:
#   https://<your-domain>/api/integrations/oauth2/whoop/callback
# Webhooks are HMAC-signed with WHOOP_CLIENT_SECRET (no extra secret needed):
#   https://<your-domain>/api/integrations/webhook/whoop
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# ---- Mobile biometrics (Apple Health / Android Health Connect) ----
# Apple HealthKit and Android Health Connect are on-device; data arrives only
# from the LeafJourney mobile app POSTing to /api/mobile/biometrics/sync with
# this bearer token. Unset => the endpoint fails closed (503) and the Apple/
# Android cards read "Coming soon". Generate with `openssl rand -hex 32`.
MOBILE_BIOMETRICS_TOKEN=
